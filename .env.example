# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=changelogai
DB_USERNAME=changelogai
DB_PASSWORD=changelogai

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=your-secret-key-at-least-256-bits-long-for-hs256-algorithm

# CORS
CORS_ORIGINS=http://localhost:3000

# GitHub OAuth (https://github.com/settings/developers)
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_WEBHOOK_SECRET=your-github-webhook-secret

# GitLab OAuth (https://gitlab.com/-/user_settings/applications)
GITLAB_URL=https://gitlab.com
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=

# Bitbucket Cloud OAuth (https://bitbucket.org/account/settings/app-authorizations/)
BITBUCKET_CLIENT_ID=
BITBUCKET_CLIENT_SECRET=

# Bitbucket Data Center (self-hosted, PAT auth)
BITBUCKET_DC_URL=

# OpenAI
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# GitHub PAT (for MCP Server — diff fetching, LOC analysis)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# MCP Server
MCP_SERVER_URL=http://localhost:3100
MCP_ENABLED=true

# Mail (SendGrid)
MAIL_HOST=smtp.sendgrid.net
MAIL_PORT=587
MAIL_USERNAME=apikey
MAIL_PASSWORD=your-sendgrid-api-key
